{
  "name": "rms-discord",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev:web": "pnpm --filter @rms-discord/web dev",
    "dev:electron": "pnpm --filter @rms-discord/electron-renderer dev",
    "build:web": "pnpm --filter @rms-discord/web build",
    "build:electron": "pnpm --filter @rms-discord/electron-renderer build",
    "electron:start": "cd electron && npm start",
    "electron:build": "pnpm build:electron && cd electron && npm run build"
  },
  "devDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.54.0",
    "rollup": "^4.55.1",
    "typescript": "~5.9.3"
  },
  "dependencies": {
    "vue-draggable-plus": "^0.6.1"
  }
}
